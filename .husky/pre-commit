#!/bin/sh

# Ensure Node.js 20+ for Cucumber tests in this hook.
if [ -z "$NVM_DIR" ]; then
  export NVM_DIR="$HOME/.nvm"
fi
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
fi
if command -v nvm >/dev/null 2>&1 && [ -f ".nvmrc" ]; then
  nvm use >/dev/null 2>&1 || nvm install >/dev/null 2>&1 || true
fi

NODE_VERSION="$(node -v 2>/dev/null || true)"
if [ -z "$NODE_VERSION" ]; then
  echo ""
  echo "❌ ERROR: Node.js not found."
  echo "Please install Node.js 20+ and retry."
  echo ""
  exit 1
fi
NODE_MAJOR="$(echo "$NODE_VERSION" | sed -E 's/^v([0-9]+).*/\1/')"
if [ "$NODE_MAJOR" -lt 20 ]; then
  echo ""
  echo "❌ ERROR: Node.js 20+ is required for pre-commit tests."
  echo "Current Node.js: $NODE_VERSION"
  echo "Try: nvm use (or nvm install) in this repo."
  echo ""
  exit 1
fi

# Check for package-lock.json - we use yarn, not npm
if [ -f "package-lock.json" ] || [ -f "test-docusaurus-site/package-lock.json" ]; then
  echo ""
  echo "⚠️  WARNING: package-lock.json detected!"
  echo ""
  echo "This project uses yarn, not npm. The CI/CD pipeline will fail."
  echo "Please remove package-lock.json and use 'yarn install' instead of 'npm install'."
  echo ""
  echo "To fix:"
  echo "  rm -f package-lock.json test-docusaurus-site/package-lock.json"
  echo ""
fi

# Check that yarn.lock files exist
if [ ! -f "yarn.lock" ]; then
  echo ""
  echo "⚠️  WARNING: yarn.lock is missing in root!"
  echo ""
  echo "The CI/CD pipeline will fail. Run 'yarn install' to generate it."
  echo ""
fi

if [ ! -f "test-docusaurus-site/yarn.lock" ]; then
  echo ""
  echo "⚠️  WARNING: yarn.lock is missing in test-docusaurus-site!"
  echo ""
  echo "The CI/CD pipeline will fail. Run 'cd test-docusaurus-site && yarn install' to generate it."
  echo ""
fi

# Run linting - this is a WARNING only, not blocking
echo "🔍 Running linters..."
if ! yarn lint:js 2>/dev/null; then
  echo ""
  echo "⚠️  WARNING: ESLint found issues!"
  echo "  Run 'yarn lint:fix' to auto-fix some issues."
  echo ""
fi

if ! yarn lint:md 2>/dev/null; then
  echo ""
  echo "⚠️  WARNING: Markdownlint found issues!"
  echo "  Run 'yarn lint:fix' to auto-fix some issues."
  echo ""
fi

# Run BDD tests - this IS blocking
echo "🧪 Running BDD tests..."
if ! yarn test; then
  echo ""
  echo "❌ ERROR: BDD tests failed!"
  echo ""
  echo "Please fix the failing tests before committing."
  echo ""
  exit 1
fi
echo "✅ BDD tests passed"
